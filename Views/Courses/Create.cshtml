@model Test.Models.Course

@{
    ViewData["Title"] = "Thêm Học Phần Mới";
}



<div class="container">
    <div class="form-card">
        <h1 class="h3 form-title">Thêm Học Phần Mới</h1>
        
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="Name" class="form-label-custom">Tên học phần</label>
                <input asp-for="Name" class="form-control form-control-custom" placeholder="Ví dụ: Lập trình C# cơ bản" />
                <span asp-validation-for="Name" class="text-danger-custom"></span>
            </div>

            <div class="form-group-custom">
                <label class="form-label-custom">Hình ảnh học phần</label>
                <input type="file" name="imageFile" class="form-control form-control-custom" accept="image/*" />
            </div>

            <div class="form-group-custom">
                <label asp-for="Credits" class="form-label-custom">Số tín chỉ</label>
                <input asp-for="Credits" type="number" class="form-control form-control-custom" min="1" max="10" placeholder="Số tín chỉ (1 - 10)" />
                <span asp-validation-for="Credits" class="text-danger-custom"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Lecturer" class="form-label-custom">Giảng viên phụ trách</label>
                <input asp-for="Lecturer" class="form-control form-control-custom" placeholder="Ví dụ: TS. Nguyễn Văn A" />
                <span asp-validation-for="Lecturer" class="text-danger-custom"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="CategoryId" class="form-label-custom">Thể loại chuyên ngành</label>
                <select asp-for="CategoryId" class="form-control form-control-custom" asp-items="ViewBag.CategoryId"></select>
                <span asp-validation-for="CategoryId" class="text-danger-custom"></span>
            </div>

            <button type="submit" class="btn-submit-custom">Lưu thông tin</button>
            <a asp-action="Index" class="btn-back-custom">Hủy & Quay lại</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
