@model Test.Models.Course

@{
    ViewData["Title"] = "Xóa Học Phần";
}



<div class="container">
    <div class="delete-card">
        <div class="warning-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-exclamation-triangle-fill" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
            </svg>
        </div>
        
        <h1 class="h3 delete-title">Xác Nhận Xóa</h1>
        <p class="delete-subtitle">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa học phần này?</p>
        
        <div class="course-details">
            <div class="detail-item">
                <span class="detail-label">Tên học phần:</span>
                <span class="detail-value text-end">@Model.Name</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Thể loại:</span>
                <span class="detail-value">@(Model.Category?.Name ?? "N/A")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Số tín chỉ:</span>
                <span class="detail-value">@Model.Credits</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Giảng viên:</span>
                <span class="detail-value">@Model.Lecturer</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-delete-confirm">Xác Nhận Xóa Học Phần</button>
            <a asp-action="Index" class="btn-cancel">Hủy bỏ</a>
        </form>
    </div>
</div>
