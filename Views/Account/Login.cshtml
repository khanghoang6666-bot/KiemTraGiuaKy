@model Test.Models.LoginViewModel

@{
    ViewData["Title"] = "Đăng Nhập";
}



<div class="container">
    <div class="login-card">
        <h1 class="h2 login-title">Đăng Nhập</h1>
        <p class="login-subtitle">Chào mừng bạn quay lại hệ thống</p>
        
        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
            <div asp-validation-summary="ModelOnly" class="text-danger-custom"></div>

            <div class="form-group-custom">
                <label asp-for="Username" class="form-label-custom">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control form-control-custom" placeholder="Nhập tên đăng nhập..." autocomplete="username" />
                <span asp-validation-for="Username" class="text-danger-custom"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Password" class="form-label-custom">Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control form-control-custom" placeholder="Nhập mật khẩu..." autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger-custom"></span>
            </div>

            <div class="form-group-custom">
                <label class="checkbox-container-custom">
                    <input asp-for="RememberMe" type="checkbox" class="checkbox-custom" />
                    Ghi nhớ đăng nhập
                </label>
            </div>

            <button type="submit" class="btn-login-custom">Đăng Nhập</button>
        </form>

        <div class="register-link-container">
            Chưa có tài khoản? <a asp-action="Register" class="register-link">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
