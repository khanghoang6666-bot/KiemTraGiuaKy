@model IEnumerable<Test.Models.Course>

@{
    ViewData["Title"] = "Học Phần Của Tôi";
}



<div class="container py-2">
    <!-- Hero Section -->
    <div class="hero-section text-center text-md-start d-md-flex justify-content-between align-items-center">
        <div>
            <h1 class="display-5 fw-800 mb-2" style="font-weight: 800; letter-spacing: -1px;">Học Phần Đã Đăng Ký</h1>
            <p class="lead mb-0 text-white-50">Xem lại và quản lý các lớp học phần bạn đang theo học trong học kỳ này.</p>
        </div>
        <div class="mt-3 mt-md-0">
            <span class="badge bg-white text-info px-3 py-2 rounded-pill fw-600">Đã đăng ký: @Model.Count() môn</span>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var course in Model)
            {
                if (course != null)
                {
                    <div class="col">
                        <div class="course-card">
                            <div class="course-img-wrapper">
                                @if (!string.IsNullOrEmpty(course.Category?.Name))
                                {
                                    <span class="category-badge">@course.Category.Name</span>
                                }
                                @if (!string.IsNullOrEmpty(course.Image))
                                {
                                    <img src="@course.Image" alt="@course.Name" class="course-img" loading="lazy" />
                                }
                                else
                                {
                                    <div class="course-img-fallback">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-book-half" viewBox="0 0 16 16">
                                            <path d="M8.5 2.687c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783"/>
                                        </svg>
                                    </div>
                                }
                            </div>
                            <div class="card-body">
                                <h3 class="course-title">@course.Name</h3>
                                
                                <div class="course-meta mt-auto">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill course-meta-icon" viewBox="0 0 16 16">
                                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                                    </svg>
                                    <span>Giảng viên: <strong>@course.Lecturer</strong></span>
                                </div>

                                <div class="course-meta">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-journal-bookmark-fill course-meta-icon" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M6 1h6v7a.5.5 0 0 1-.757.429L9 7.083 6.757 8.43A.5.5 0 0 1 6 8z"/>
                                        <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1c0-.218.019-.432.056-.642A3 3 0 0 1 0 13V3a3 3 0 0 1 1.056-2.358A2 2 0 0 1 3 0"/>
                                        <path d="M1 3v10h1a2 2 0 0 0 2 2h9a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H4a2 2 0 0 0-2 2z"/>
                                    </svg>
                                    <span class="credits-badge">@course.Credits tín chỉ</span>
                                </div>

                                <form asp-controller="Enroll" asp-action="Cancel" method="post" class="mt-3">
                                    <input type="hidden" name="courseId" value="@course.Id" />
                                    <button type="submit" class="btn btn-outline-danger w-100" style="border-radius:10px; font-weight:600; padding: 0.5rem;">Hủy Đăng Ký</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="empty-state-card">
            <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-journal-x" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M6.146 6.146a.5.5 0 0 1 .708 0L8 7.293l1.146-1.147a.5.5 0 1 1 .708.708L8.707 8l1.147 1.146a.5.5 0 0 1-.708.708L8 8.707l-1.146 1.147a.5.5 0 0 1-.708-.708L7.293 8 6.146 6.854a.5.5 0 0 1 0-.708"/>
                    <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1c0-.218.019-.432.056-.642A3 3 0 0 1 0 13V3a3 3 0 0 1 1.056-2.358A2 2 0 0 1 3 0m10 2v12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h9z"/>
                </svg>
            </div>
            <h3 class="h4 fw-700 text-slate-800" style="font-weight: 700;">Danh Sách Trống</h3>
            <p class="text-muted">Bạn chưa đăng ký học phần nào trong học kỳ này.</p>
            <a asp-controller="Home" asp-action="Index" class="btn-explore">Đăng ký học phần ngay</a>
        </div>
    }
</div>
